{
  "uid": "sandbox-command-latency",
  "title": "Sandbox Command Latency",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "tags": ["sandbox", "metrics", "commands"],
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Runtime operation average latency",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (operation, status) (sandbox_runtime_operation_latency_ms_milliseconds_sum{operation=~\"exec_command|write_command_stdin|read_command_lines\"}) / sum by (operation, status) (sandbox_runtime_operation_latency_ms_milliseconds_count{operation=~\"exec_command|write_command_stdin|read_command_lines\"})",
          "legendFormat": "{{operation}} {{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms" },
        "overrides": []
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "title": "Command operation rate by status",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(sandbox_runtime_operation_latency_ms_milliseconds_count{operation=~\"exec_command|write_command_stdin|read_command_lines\"}[5m])) by (operation, status)",
          "legendFormat": "{{operation}} {{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 10 }
    }
  ]
}
