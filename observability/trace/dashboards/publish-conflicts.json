{
  "uid": "sandbox-publish-conflicts",
  "title": "Sandbox Publish Conflicts",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "tags": ["sandbox", "metrics", "publish"],
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Publish rejections",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(sandbox_publish_rejections_total) by (bounded_reason)",
          "legendFormat": "{{bounded_reason}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "title": "Publish phase average latency",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status) (sandbox_workspace_phase_latency_ms_milliseconds_sum{workspace_phase=\"publish_changes\"}) / sum by (status) (sandbox_workspace_phase_latency_ms_milliseconds_count{workspace_phase=\"publish_changes\"})",
          "legendFormat": "{{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms" },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 10 }
    }
  ]
}
